  "keyFeatures": [
    "User authentication with role-based access control (students, teachers, administrators)",
    "Course catalog with 15+ categories including Web Development, Cybersecurity, and AI",
    "Markdown-based course content creation and management",
    "Student enrollment and progress tracking",
    "Admin dashboard for managing teacher requests and platform statistics",
    "RESTful API for programmatic course content management",
    "Profile management with avatar support",
    "Course search and filtering by category"
  ],
  "publicApiSurface": [
    "GetMd.php - Retrieve markdown content for a specific chapter",
    "SaveMd.php - Save markdown content for a chapter",
    "NewCours.php - Create a new course",
    "NewChapter.php - Add a new chapter to a course",
    "UploadImage.php - Upload images for course content",
    "CleanImg.php - Remove unused images",
    "CreateAccount.php - Create new user accounts (disabled in production)"
  ]
